# Core
APP_NAME=Affiliate Tracking Integrity Monitoring
APP_ENV=development
APP_VERSION=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://mvp:mvp@postgres:5432/mvp
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PYTHONPATH=/app/mvp:/app
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8000
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=100
AUTH_MODE=local
FRONTEND_BASE_URL=https://dailystack-affiliate.vercel.app
CORS_ALLOW_ORIGINS=https://dailystack-affiliate.vercel.app
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=
SUPABASE_JWKS_CACHE_SECONDS=600
SCAN_ALLOWED_HOSTS=
SCAN_DENIED_HOSTS=
SCAN_ALLOWED_CIDRS=
SCAN_DENIED_CIDRS=
SCAN_ALLOW_PROXY_URLS=false
RESEND_API_KEY=
DISCORD_WEBHOOK_URL=
# Secrets
API_KEY_SECRET=change-me
JWT_SECRET_KEY=change-me

# Email / Alerts
EMAIL_FROM=mvp@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_RECIPIENTS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICING_TABLE_ID=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=https://dailystack-affiliate.vercel.app/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://dailystack-affiliate.vercel.app/payment/cancel

# App URLs
API_BASE_URL=https://cilantro-browse-duress.ngrok-free.dev

